rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 헬퍼 함수 ──
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin() { return getUserRole() == 'admin'; }
    function isReceiver() { return getUserRole() == 'receiver'; }
    function isReviewer() { return getUserRole() == 'reviewer' || isAdmin(); }

    // 초기설정 완료 여부 (settings/orgInfo 존재 여부로 판단)
    function isSetupDone() {
      return exists(/databases/$(database)/documents/settings/orgInfo);
    }

    // ── settings/orgInfo: 비로그인도 읽기 가능 (초기화 여부 확인용) ──
    match /settings/orgInfo {
      allow read: if true;
      allow write: if (request.auth != null && isAdmin()) ||
                      (request.auth != null && !isSetupDone());
    }

    // ── settings 나머지: 로그인 필요 ──
    match /settings/{document=**} {
      allow read: if request.auth != null;
      allow write: if (request.auth != null && isAdmin()) ||
                      (request.auth != null && !isSetupDone());
    }

    // ── users: 초기설정 전에는 누구나(로그인) 쓰기 가능 (첫 관리자 생성) ──
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if (request.auth != null && isAdmin()) ||
                      (request.auth != null && !isSetupDone());
    }

    // ── documents 컬렉션 ──
    match /documents/{docId} {
      allow read: if request.auth != null &&
        (isReceiver() || isAdmin() || isReviewer() ||
         resource.data.assigneeEmail == request.auth.token.email);

      allow create: if request.auth != null &&
        (isReceiver() || isAdmin()) &&
        request.resource.data.receiptUserEmail == request.auth.token.email &&
        request.resource.data.receiptDate != null &&
        request.resource.data.title != null;

      allow update: if request.auth != null &&
        (isReceiver() || isAdmin() || isReviewer() ||
         resource.data.assigneeEmail == request.auth.token.email) &&
        (request.resource.data.receiptUserEmail == resource.data.receiptUserEmail);

      allow delete: if isAdmin();
    }

    // ── reviewHistory 서브컬렉션 ──
    match /documents/{docId}/reviewHistory/{historyId} {
      allow read: if request.auth != null && (isReceiver() || isAdmin() || isReviewer());
      allow create: if request.auth != null &&
        request.resource.data.reviewerEmail == request.auth.token.email;
      allow delete: if isAdmin();
    }

    // ── 미정의 경로 전부 거부 ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
